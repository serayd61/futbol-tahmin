# ============================================================
# n8n ortam değişkenleri — bu dosyanın KOPYASINI .env olarak oluştur,
# içini kendi anahtarlarınla doldur. .env dosyası gitignore'da.
# ============================================================

# n8n panel girişi (istediğini seç, sadece sen kullanacaksın)
N8N_USER=admin
N8N_PASSWORD=DEGISTIR_BURAYI_GUCLU_BIR_SIFRE

# Football-Data.org → My Account → API Token
FOOTBALL_DATA_API_KEY=

# API-Football (direkt) → dashboard.api-football.com → Account → API Key
APIFOOTBALL_DIRECT_KEY=

# (Opsiyonel — Plan A için, RapidAPI üzerinden api-football kullanırsan)
RAPIDAPI_KEY=

# Supabase → Project Settings → API
SUPABASE_URL=https://dfaeelstabyoouuoivzd.supabase.co
SUPABASE_SERVICE_KEY=
